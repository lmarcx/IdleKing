{
  "name": "@idleking/game-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./power": "./dist/power/index.js",
    "./loot": "./dist/loot/index.js",
    "./progression": "./dist/progression/index.js",
    "./character": "./dist/character/index.js",
    "./equipment": "./dist/equipment/index.js",
    "./game/*": "./dist/game/*",
    "./building/*": "./dist/building/*",
    "./bank": "./dist/bank/index.js",
    "./bank/*": "./dist/bank/*",
    "./currencies": "./dist/currencies/index.js",
    "./currencies/*": "./dist/currencies/*",
    "./minigames": "./dist/minigames/index.js",
    "./minigames/farm": "./dist/minigames/farm/index.js",
    "./minigames/mine": "./dist/minigames/mine/index.js",
    "./minigames/*": "./dist/minigames/*",
    "./resources/*": "./dist/resources/*",
    "./items": "./dist/items/index.js",
    "./story": "./dist/story/index.js",
    "./items/*": "./dist/items/*"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/__tests__/*.js"
  }
}
